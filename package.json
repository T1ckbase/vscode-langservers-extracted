{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "@t1ckbase/vscode-langservers-extracted",
  "version": "0.1.15",
  "description": "Extracted language servers from Microsoft’s repositories for various languages (CSS, HTML, JSON), including Anycode and ESLint.",
  "keywords": [
    "anycode",
    "css",
    "eslint",
    "html",
    "json",
    "language-server",
    "language-server-protocol",
    "lsp",
    "vscode"
  ],
  "bugs": {
    "url": "https://github.com/T1ckbase/vscode-langservers-extracted/issues"
  },
  "license": "MIT",
  "author": "t1ckbase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/T1ckbase/vscode-langservers-extracted"
  },
  "bin": {
    "vscode-anycode-language-server": "dist/anycode/anycode.server.node.js",
    "vscode-css-language-server": "dist/css/cssServerMain.js",
    "vscode-eslint-language-server": "dist/eslint/eslintServer.js",
    "vscode-html-language-server": "dist/html/htmlServerMain.js",
    "vscode-json-language-server": "dist/json/jsonServerMain.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "metadata": {
    "versions": {
      "microsoft/vscode": "1.108.2",
      "microsoft/vscode-eslint": "3.0.20",
      "microsoft/vscode-anycode": "0.0.75"
    }
  }
}
