{
  "$schema": "http://www.schemastore.org/package.json",
  "name": "@t1ckbase/vscode-langservers-extracted",
  "version": "1.0.4",
  "description": "Extracted language servers from Microsoft’s repositories for various languages (CSS, HTML, JSON) and ESLint.",
  "keywords": [
    "css",
    "emacs",
    "eslint",
    "helix",
    "html",
    "json",
    "language-server",
    "language-server-protocol",
    "lsp",
    "neovim",
    "vim",
    "vscode"
  ],
  "bugs": {
    "url": "https://github.com/T1ckbase/vscode-langservers-extracted/issues"
  },
  "license": "MIT",
  "author": "t1ckbase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/T1ckbase/vscode-langservers-extracted.git"
  },
  "bin": {
    "vscode-css-language-server": "dist/css/cssServerMain.js",
    "vscode-eslint-language-server": "dist/eslint/eslintServer.js",
    "vscode-html-language-server": "dist/html/htmlServerMain.js",
    "vscode-json-language-server": "dist/json/jsonServerMain.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.41.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "metadata": {
    "versions": {
      "microsoft/vscode": "1.117.0",
      "microsoft/vscode-eslint": "3.0.24"
    }
  }
}
